{
  "name": "main-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:client": "openapi-generator-cli generate --generator-key auth-api",
    "postgenerate:client": "node scripts/post-generate.mjs",
    "generate:client:local": "openapi-generator-cli generate -g typescript-angular -i spec/openapi.json -o src/app/generated/auth-api --additional-properties=providedInRoot=true,fileNaming=kebab-case,withInterfaces=true,useSingleRequestParameter=true,supportsES6=true",
    "generate:client:subscription": "openapi-generator-cli generate --generator-key subscription-api && node scripts/post-generate-subscription.mjs",
    "generate:client:subscription:local": "openapi-generator-cli generate -g typescript-angular -i spec/subscription.json -o src/app/generated/subscription-api --additional-properties=providedInRoot=true,fileNaming=kebab-case,withInterfaces=true,useSingleRequestParameter=true,supportsES6=true && node scripts/post-generate-subscription.mjs",
    "download:spec": "node -e \"const fs=require('fs');const h='http';require(h).get('http://localhost:9000/api-docs',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{fs.mkdirSync('spec',{recursive:true});fs.writeFileSync('spec/openapi.json',d);console.log('Downloaded spec to spec/openapi.json')})})\"",
    "download:spec:subscription": "node -e \"const fs=require('fs');const h='http';require(h).get('http://localhost:8082/api-docs',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{fs.mkdirSync('spec',{recursive:true});fs.writeFileSync('spec/subscription.json',d);console.log('Downloaded spec to spec/subscription.json')})})\""
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.0",
    "@capacitor/cli": "^8.4.0",
    "@openapitools/openapi-generator-cli": "^2.39.0",
    "@types/bootstrap": "^5.2.11",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
